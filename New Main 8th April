void filterFlights() {
  displayedFlights.clear();
  scrollY = 0;

  String q = searchQuery.toLowerCase().trim();

  for (Flight f : flights) {
    if (showOnlyCancelled && !f.Cancelled.startsWith("1")) continue;
    if (showOnlyDiverted && !f.Diverted.startsWith("1")) continue;

    if (q.length() == 0) {
      displayedFlights.add(f);
    } else {
      // For airport searches, only match origin so pie chart shows outbound destinations
      if (f.airlineCode.toLowerCase().contains(q) ||
          f.origin.toLowerCase().contains(q) ||
          f.originState.toLowerCase().contains(q)) {

        displayedFlights.add(f);
      }
      else if (q.contains("dep") && !f.Cancelled.startsWith("1") && !f.Diverted.startsWith("1") && q.equals("dep" + f.DepTime.toLowerCase())) {
        displayedFlights.add(f);
      }
      else if (q.contains("arr") && !f.Cancelled.startsWith("1") && !f.Diverted.startsWith("1") && q.equals("arr" + f.ArrTime.toLowerCase())) {
        displayedFlights.add(f);
      }
    }
  }

  countFlightsByHour();
}
